<?xml version="1.0" encoding="iso-8859-1" ?>
<ZApplication Name="App" Caption="ZGameEditor application" MouseVisible="255" FileVersion="2">
  <OnLoaded>
    <ZLibrary HasInitializer="1">
      <Source>
<![CDATA[private inline int min(int x, int y) {
  return x<y ? x : y;
}

private inline int max(int x, int y) {
  return x>y ? x : y;
}

float[4] channelLevels;

// Code based on: https://atornblad.github.io/js-mod-player/

private const int NotUsed = -9999;

class Instrument {
    int index;
    string name;
    int length;
    int finetune;
    int volume;
    int repeatoffset;
    int repeatLength;
    byte[] bytes;
    int isLooped;

    Instrument(byte[] modfile, int index, int sampleStart) {
        int offset = 20 + index * 30;
        //const data = new Uint8Array(modfile, 20 + index * 30, 30);
        //const nameBytes = data.slice(0, 21).filter(a => !!a);
        this.index = index;
        //this.name = String.fromCodePoint(...nameBytes).trim();

        this.length = 2 * (modfile[offset + 22] * 256 + modfile[offset + 23]);
        this.finetune = modfile[offset + 24];
        if (this.finetune > 7) this.finetune -= 16;
        this.volume = modfile[offset + 25];
        this.repeatOffset = 2 * (modfile[offset + 26] * 256 + modfile[offset + 27]);
        this.repeatLength = 2 * (modfile[offset + 28] * 256 + modfile[offset + 29]);

        //this.bytes = new Int8Array(modfile, sampleStart, this.length);
        bytes.SizeDim1 = length;
        for(int i=0; i<length; i++) {
          bytes[i] = modfile[sampleStart + i];
        }

        this.isLooped = this.repeatOffset != 0 || this.repeatLength > 2;
    }
}

class Note {
    int instrument, period, effectId, effectData, effectHigh, effectLow, hasEffect, rawEffect;
    Note(byte[] noteData, int offset) {
        // The data for each note is bit-packed like this:
        //  Byte 0   Byte 1   Byte 2   Byte 3
        // 76543210 76543210 76543210 76543210
        // iiiipppp pppppppp iiiieeee eeeeeeee
        // i = instrument index
        // p = period
        // e = effect
        this.instrument = (noteData[offset + 0] & 0xf0) | (noteData[offset + 2] >> 4);
        int i=this.instrument;
        this.period = (noteData[offset + 0] & 0x0f) * 256 + noteData[offset + 1];
        int _effectId = noteData[offset + 2] & 0x0f;
        int _effectData = noteData[offset + 3];
        if (_effectId == 0x0e) {
            _effectId = 0xe0 | (_effectData >> 4);
            _effectData &= 0x0f;
        }
        this.rawEffect = ((noteData[offset + 2] & 0x0f) << 8) | noteData[offset + 3];
        this.effectId = _effectId;
        this.effectData = _effectData;
        this.effectHigh = _effectData >> 4;
        this.effectLow = _effectData & 0x0f;
        this.hasEffect = _effectId || _effectData;
    }
}

class Row {
    Note[] notes;

    Row(byte[] rowData, int offset) {
        // Each note is 4 bytes
        for (int i = 0; i < 16; i += 4) {
            Note not = new Note(rowData, offset + i);
            notes += not;
        }
    }
}

class Pattern {
    Row[] rows;
    Pattern(byte[] modfile, int index) {
        // Each pattern is 1024 bytes long
        // Each pattern is made up of 64 rows
        for (int i = 0; i < 64; i++) {
            // Each row is made up of 16 bytes
            Row r = new Row(modfile, 1084 + index * 1024 + i * 16);
            rows += r;
        }
    }
}


class Mod {
    int length;
    Instrument[] instruments;
    byte[128] patternTable;
    Pattern[] patterns;
    Mod(byte[] modfile) {
        //const nameArray = new Uint8Array(modfile, 0, 20);
        //const nameBytes = nameArray.filter(a => !!a);
        //this.name = String.fromCodePoint(...nameBytes).trim();

        // Store the song length
        this.length = modfile[950];

        // Store the pattern table
        int maxPatternIndex = 0;
        for(int i = 0; i<patternTable.SizeDim1; i++) {
          byte b = modfile[952 + i];
          if(b>maxPatternIndex)
            maxPatternIndex = b;
          patternTable[i] = b;
        }
        trace("Max pat " + intToStr(maxPatternIndex));
        // Extract all instruments
        instruments.SizeDim1 = 0;
        instruments += null; // let first be empty
        int sampleStart = 1084 + (maxPatternIndex + 1) * 1024;
        for (int i = 0; i < 31; ++i) {
            Instrument instr = new Instrument(modfile, i, sampleStart);
            instruments += instr;
            sampleStart += instr.length;
        }

        // Extract the pattern data
        for (int i = 0; i <= maxPatternIndex; ++i) {
            Pattern pat = new Pattern(modfile, i);
            patterns += pat;
        }
    }
}

private const float PAULA_FREQUENCY = 3546894.6;
private const float ZGE_SAMPLE_RATE = 44100.0;

private const int FX_ARPEGGIO = 0x00;
private const int FX_SLIDE_UP = 0x01;
private const int FX_SLIDE_DOWN = 0x02;
private const int FX_TONE_PORTAMENTO = 0x03;
private const int FX_VIBRATO = 0x04;
private const int FX_TONE_PORTAMENTO_WITH_VOLUME_SLIDE = 0x05;
private const int FX_VIBRATO_WITH_VOLUME_SLIDE = 0x06;
private const int FX_SAMPLE_OFFSET = 0x09;
private const int FX_VOLUME_SLIDE = 0x0A;
private const int FX_SET_VOLUME = 0x0C;
private const int FX_PATTERN_BREAK = 0x0D;
private const int FX_EXTENDED = 0x0e;
private const int FX_SET_SPEED = 0x0f;
private const int FX_PORTA_UP_FINE = 0xe1;
private const int FX_PORTA_DOWN_FINE = 0xe2;
private const int FX_RETRIGGER_NOTE = 0xe9;
private const int FX_VOLUME_SLIDE_UP_FINE = 0xea;
private const int FX_VOLUME_SLIDE_DOWN_FINE = 0xeb;
private const int FX_DELAY_NOTE = 0xed;
private const int true = 1, false = 0;

private int globalTick = 0;


class Channel {
    Instrument instr, setInstrument;
    int playing, period, currentPeriod, portamentoSpeed, periodDelta, vibratoSpeed,
      vibratoIndex, vibratoDepth, vibrato, arpeggio, volumeSlide, retrigger, delayNote,
      portamento;
    float sampleIndex, sampleSpeed;
    int volume, currentVolume;
    byte[] arpeggio_table;
    int setVolume, setPeriod, setSampleIndex, setCurrentPeriod;
    Channel() {
        this.volume = 64;
        this.currentVolume = 64;
    }

    Mod theMod;

    float nextOutput() {
        if ( (this.instr==null) || !this.period)
          return 0.0;

        int location = round(this.sampleIndex);
        if(location >= this.instr.length) {
          //trace("fail " + intToStr(this.instr.length));
          location = 0;
        }
        int sample = this.instr.bytes[ location ];
        if(sample >= 128)
          sample = sample - 256;

        this.sampleIndex += this.sampleSpeed;

        if (this.instr.isLooped) {
            if (this.sampleIndex >= this.instr.repeatOffset + this.instr.repeatLength) {
                this.sampleIndex = this.instr.repeatOffset;
            }
        }
        else if (this.sampleIndex >= this.instr.length) {
            return 0.0;
        }

        return sample / 256.0 * this.currentVolume / 64;
    }

    void performTick() {
        if (this.volumeSlide && globalTick > 0) {
            this.currentVolume += this.volumeSlide;
            if (this.currentVolume < 0) this.currentVolume = 0;
            if (this.currentVolume > 64) this.currentVolume = 64;
        }

        if (this.vibrato) {
            this.vibratoIndex = (this.vibratoIndex + this.vibratoSpeed) % 64;
            this.currentPeriod = this.period + sin(this.vibratoIndex / 64 * PI * 2) * this.vibratoDepth;
        }
        else if (this.periodDelta) {
            if (this.portamento) {
                if (this.currentPeriod != this.period) {
                    int sign = this.period - this.currentPeriod;
                    int distance = abs(this.currentPeriod - this.period);
                    int diff = min(distance, this.periodDelta);
                    if(sign<0)
                      diff *= -1;
                    this.currentPeriod += diff;
                }
            }
            else {
                this.currentPeriod += this.periodDelta;
            }
        }
        else if (this.arpeggio) {
            int index = globalTick % this.arpeggio_table.SizeDim1;
            int halfNotes = this.arpeggio_table[index];
            this.currentPeriod = this.period / pow(2, halfNotes / 12);
        }
        else if (this.retrigger && (globalTick % this.retrigger) == 0) {
            this.sampleIndex = 0;
        }
        else if (this.delayNote == globalTick) {
            this.instr = this.setInstrument;
            this.volume = this.setVolume;
            this.currentVolume = this.volume;
            this.period = this.setPeriod;
            this.currentPeriod = this.period;
            this.sampleIndex = 0;
        }

        if (this.currentPeriod < 113) this.currentPeriod = 113;
        if (this.currentPeriod > 856) this.currentPeriod = 856;

        float rate = PAULA_FREQUENCY / this.currentPeriod;
        this.sampleSpeed = rate / ZGE_SAMPLE_RATE;
    }

    void effect(int hasEffect, int effectId, int effectData, int effectHigh, int effectLow) {
        this.volumeSlide = 0;
        this.periodDelta = 0;
        this.portamento = false;
        this.vibrato = false;
        this.arpeggio = false;
        this.retrigger = false;
        this.delayNote = false;

        if (!hasEffect) return;

        switch (effectId) {
            case FX_ARPEGGIO:
                //this.arpeggio_table = {0, effectHigh, effectLow};
                trace("TODO ARPEGGIO");
                break;
            case FX_SLIDE_UP:
                this.periodDelta = -effectData;
                break;
            case FX_SLIDE_DOWN:
                this.periodDelta = effectData;
                break;
            case FX_TONE_PORTAMENTO:
                this.portamento = true;
                if (effectData) this.portamentoSpeed = effectData;
                this.periodDelta = this.portamentoSpeed;
                this.setCurrentPeriod = false;
                this.setSampleIndex = false;
                break;
            case FX_PORTA_UP_FINE:
                this.setPeriod = this.period - effectData;
                break;
            case FX_PORTA_DOWN_FINE:
                this.setPeriod = this.period + effectData;
                break;
            case FX_VIBRATO:
                if (effectHigh) this.vibratoSpeed = effectHigh;
                if (effectLow) this.vibratoDepth = effectLow;
                this.vibrato = true;
                break;
            case FX_TONE_PORTAMENTO_WITH_VOLUME_SLIDE:
                this.portamento = true;
                this.setCurrentPeriod = NotUsed;
                this.setSampleIndex = NotUsed;
                this.periodDelta = this.portamentoSpeed;
                if (effectHigh) this.volumeSlide = effectHigh;
                else if (effectLow) this.volumeSlide = -effectLow;
                break;
            case FX_VIBRATO_WITH_VOLUME_SLIDE:
                this.vibrato = true;
                if (effectHigh) this.volumeSlide = effectHigh;
                else if (effectLow) this.volumeSlide = -effectLow;
                break;
            case FX_VOLUME_SLIDE:
                if (effectHigh) this.volumeSlide = effectHigh;
                else if (effectLow) this.volumeSlide = -effectLow;
                break;
            case FX_VOLUME_SLIDE_UP_FINE:
                this.setVolume = min(64, this.volume + effectData);
                break;
            case FX_VOLUME_SLIDE_DOWN_FINE:
                this.setVolume = max(0, this.volume - effectData);
                break;
            case FX_SAMPLE_OFFSET:
                this.setSampleIndex = effectData * 256;
                break;
            case FX_SET_VOLUME:
                this.setVolume = effectData;
                break;
            case FX_PATTERN_BREAK:
                int row = effectHigh * 10 + effectLow;
                //this.worklet.setPatternBreak(row);
                trace("TODO: setPatternBreak " + intToStr(row));
                break;
            case FX_SET_SPEED:
                if (effectData >= 1 && effectData <= 31) {
                  //  this.worklet.setTicksPerRow(effectData);
                  trace("TODO: setTicksPerRow " + intToStr(effectData));
                }
                else {
                   // this.worklet.setBpm(effectData);
                  trace("TODO: set bpm " + intToStr(effectData));
                }
                break;
            case FX_RETRIGGER_NOTE:
                this.retrigger = effectData;
                break;
            case FX_DELAY_NOTE:
               this.delayNote = effectData;
               break;
            default : {
              trace("Unsupported effect: " + intToStr(effectId));
            }
        }
    }

    void play(Note not) {
        this.setVolume = NotUsed;
        this.setPeriod = NotUsed;
        this.delayNote = NotUsed;
        this.setInstrument = null;

        if (not.instrument) {
            int i = not.instrument;
            this.setInstrument = theMod.instruments[not.instrument];
            this.setVolume = this.setInstrument.volume;
        }

        this.setSampleIndex = NotUsed;
        this.setCurrentPeriod = NotUsed;

        if (not.period) {
            Instrument ins = this.setInstrument;
            if(ins==null)
              ins = this.instr;
            int finetune = (ins!=null) && (ins.finetune || 0);
            this.setPeriod = not.period - finetune;
            this.setCurrentPeriod = 1;
            this.setSampleIndex = 0;
        }


        this.effect(not.hasEffect, not.effectId, not.effectData, not.effectHigh, not.effectLow);

        if (this.delayNote)
          return;

        if (this.setInstrument != null) {
            this.instr = this.setInstrument;
        }

        if (this.setVolume != NotUsed) {
            this.volume = this.setVolume;
            this.currentVolume = this.volume;
        }

        if (this.setPeriod) {
            this.period = this.setPeriod;
        }

        if (this.setCurrentPeriod) {
            this.currentPeriod = this.period;
        }

        if (this.setSampleIndex != NotUsed) {
            this.sampleIndex = this.setSampleIndex;
        }
    }

}

class ModPlayer  {

    Channel[4] channels;
    Mod theMod;
    int position, rowIndex, ticksPerRow, outputsUntilNextTick, playing,
      patternBreak, bpm, outputsPerTick;

     ModPlayer() {
        channels[0] = new Channel();
        channels[1] = new Channel();
        channels[2] = new Channel();
        channels[3] = new Channel();
        this.patternBreak = NotUsed;
    }

    void setTicksPerRow(int ticksPerRow) {
        this.ticksPerRow = ticksPerRow;
    }

    void setBpm(int bpm) {
        this.bpm = bpm;
        this.outputsPerTick = ZGE_SAMPLE_RATE * 60 / this.bpm / 4 / 6;
    }

    void play(Mod amod) {
        this.theMod = amod;

        this.setBpm(125);
        this.setTicksPerRow(6);

        // Start at the last tick of the pattern "before the first pattern"
        this.position = -1;
        this.rowIndex = 63;
        globalTick = 5;
        this.ticksPerRow = 6;

        for (int i = 0; i < 4; i++)
            this.channels[i].theMod = amod;

        // Immediately move to the first row of the first pattern
        this.outputsUntilNextTick = 0;
        this.playing = true;
    }

    void stop() {
        this.playing = false;
    }

    int setPatternBreak(int row) {
        this.patternBreak = row;
    }

    int nextRow() {
        ++this.rowIndex;
        if (this.patternBreak != NotUsed) {
            this.rowIndex = this.patternBreak;
            ++this.position;
            this.patternBreak = NotUsed;
        }
        else if (this.rowIndex == 64) {
            this.rowIndex = 0;
            ++this.position;
        }

        if (this.position >= this.theMod.length) {
            this.position = 0;
        }

        int patternIndex = this.theMod.patternTable[this.position];
        Pattern pat = this.theMod.patterns[patternIndex];
        Row r = pat.rows[this.rowIndex];
        if (r == null)
          quit();

        for (int i = 0; i < 4; i++) {
            this.channels[i].play(r.notes[i]);
        }

    }

    void nextTick() {
        ++globalTick;
        if (globalTick == this.ticksPerRow) {
            globalTick = 0;
            this.nextRow();
        }

        for (int i = 0; i < 4; ++i) {
            this.channels[i].performTick();
        }
    }

    void updateLevels() {
      for (int i = 0; i < 4; ++i) {
          int vol = this.channels[i].volume;
          float newLevel = vol / 64.0;
          channelLevels[i] = (channelLevels[i] * 0.2) + (newLevel * 0.8);
      }
    }

    void nextOutput(ref float left, ref float right) {
        if (!this.playing)
          return;

        if (this.outputsUntilNextTick <= 0) {
            this.nextTick();
            this.outputsUntilNextTick += this.outputsPerTick;
        }

        this.outputsUntilNextTick--;

        const int chanCount = 4;
        const float majorchmul = 1.0 / (chanCount / 2.0);
        const float minorchmul = 1.0 / 3.0 / (chanCount / 2);

        left = 0.0; right = 0.0;
        for (int i = 0; i < 4; ++i) {
          float sample = this.channels[i].nextOutput();
          if((i == 1) || (i == 2)) {
            left += sample * minorchmul;
            right += sample * majorchmul;
          } else {
            left += sample * majorchmul;
            right += sample * minorchmul;
          }
        }
    }

}

Mod globalMod;
ModPlayer globalModPlayer;]]>
      </Source>
    </ZLibrary>
    <ZExpression>
      <Expression>
<![CDATA[byte[] bytes;
getBinaryProp(File1.FileEmbedded, bytes);
globalMod = new Mod(bytes);
globalModPlayer = new ModPlayer();
globalModPlayer.play(globalMod);]]>
      </Expression>
    </ZExpression>
  </OnLoaded>
  <OnUpdate>
    <ZExpression Expression="globalModPlayer.updateLevels();"/>
  </OnUpdate>
  <OnRender>
    <Repeat>
      <OnIteration>
        <RenderTransformGroup Name="Rtg1" Scale="0.1 0.1 0.1" Translate="1.5 0 0">
          <Children>
            <RenderSetColor Name="Rcol1" Color="0.6196 0.7882 0.7725 1"/>
            <RenderSprite/>
          </Children>
        </RenderTransformGroup>
      </OnIteration>
      <WhileExp>
<![CDATA[//this.Iteration=current iteration nr. Return false to end loop.
if(this.Iteration>=4)
  return 0;

Rtg1.Translate.X = -3.0 + this.Iteration * 2;
float scale = channelLevels[this.Iteration] * 2;
if(scale<0.001)
  Rtg1.Scale = 0.1;
else
  Rtg1.Scale = scale;
Rtg1.Rotate.Z = random(0, scale * 0.01);

return 1;]]>
      </WhileExp>
    </Repeat>
  </OnRender>
  <Content>
    <File Name="File1" Comment="Imported from brainblast.mod">
      <FileEmbedded>
<![CDATA[]]>
      </FileEmbedded>
    </File>
    <AudioBuffer>
      <OnFillAudioBuffer>
<![CDATA[//Data: array of destination audio buffer (stereo float)
//FrameCount : nr of audio frames to write
//Garbage collection is not working here so avoid allocate memory (strings, vectors and resizing arrays)


for(int i = 0; i < FrameCount * 2; i+= 2) {
  if( (globalModPlayer == null) || (!globalModPlayer.playing) )
    break;

  float left, right;
  globalModPlayer.nextOutput(left, right);
  Data[i] = left;
  Data[i+1] = right;
}]]>
      </OnFillAudioBuffer>
    </AudioBuffer>
  </Content>
</ZApplication>
